{"object":"value","document":{"object":"document","data":{},"nodes":[{"object":"block","type":"heading-one","data":{},"nodes":[{"object":"text","text":"Headline 1","marks":[]}]},{"object":"block","type":"heading-two","data":{"language":"js"},"nodes":[{"object":"text","text":"Headline 2","marks":[]}]},{"object":"block","type":"heading-three","data":{"language":"js"},"nodes":[{"object":"text","text":"Headline 3","marks":[]}]},{"object":"block","type":"heading-four","data":{"language":"js"},"nodes":[{"object":"text","text":"Headline 4","marks":[]}]},{"object":"block","type":"heading-five","data":{"language":"js"},"nodes":[{"object":"text","text":"Headline 5","marks":[]}]},{"object":"block","type":"heading-six","data":{"language":"js"},"nodes":[{"object":"text","text":"Headline 6","marks":[]}]},{"object":"block","type":"block-quote","data":{},"nodes":[{"object":"text","text":"Wer sich nicht mit Politik befasst, hat die politische Parteinahme, die er sich ersparen möchte, bereits vollzogen: er dient der herrschenden Partei.","marks":[]}]},{"object":"block","type":"bulleted-list","data":{},"nodes":[{"object":"block","type":"list-item","data":{},"nodes":[{"object":"text","text":"List 1","marks":[]}]},{"object":"block","type":"list-item","data":{},"nodes":[{"object":"text","text":"List 2","marks":[]}]}]},{"object":"block","type":"code","data":{"language":"js"},"nodes":[{"object":"text","text":"// A simple FizzBuzz implementation.\nfor (var i = 1; i <= 100; i++) {\n  if (i % 15 == 0) {\n    console.log('Fizz Buzz');\n  } else if (i % 5 == 0) {\n    console.log('Buzz');\n  } else if (i % 3 == 0) {\n    console.log('Fizz');\n  } else {\n    console.log(i);\n  }\n}","marks":[]}]},{"object":"block","type":"table","data":{},"nodes":[{"object":"block","type":"table_row","data":{},"nodes":[{"object":"block","type":"table_cell","data":{},"nodes":[{"object":"block","type":"paragraph","data":{},"nodes":[{"object":"text","text":"TH 1","marks":[]}]}]},{"object":"block","type":"table_cel