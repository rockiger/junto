{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"css": {
		"formatter": {
			"indentStyle": "tab"
		},
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"rules": {
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "off"
			}
		}
	}
}