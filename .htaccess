# Fulcrum.wiki – Apex → www (301)
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Apex → www (301)
  RewriteCond %{HTTP_HOST} ^fulcrum\.wiki$ [NC]
  RewriteRule ^ https://www.fulcrum.wiki%{REQUEST_URI} [R=301,L]
</IfModule>
# Fulcrum.wiki – SPA (TanStack Router / Vite) für Hostinger
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Bestehende Dateien und Ordner nicht umschreiben (JS, CSS, Bilder, …)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Alle anderen Pfade → index.html (Client-Routing)
  RewriteRule ^ index.html [L]
</IfModule>
# Optional: index.html nicht lang cachen (nach Deploy sofort neue Version)
<IfModule mod_headers.c>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|gif|svg|ico|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>